# Dandelion env vars — copy to `.env` and fill in. The dev server picks
# them up at startup; restart the server after changing this file.

# ─── Provider selection ──────────────────────────────────────────────
# Which provider to default to when no per-call override is set.
#   ollama     → local Ollama server (no key required)
#   anthropic  → Anthropic Claude API (key required)
DANDELION_PROVIDER=ollama

# ─── Anthropic (cloud) ───────────────────────────────────────────────
# Required if you want Claude models in the picker, file uploads, or
# vision/PDF inputs. Get one at https://console.anthropic.com/.
# Without this, the model picker will show only local Ollama models.
ANTHROPIC_API_KEY=
# Optional override; otherwise the curated list in scripts/providers.mjs
# is shown (Haiku 4.5, Sonnet 4.6, Opus 4.7).
ANTHROPIC_MODEL=

# ─── Ollama (local) ──────────────────────────────────────────────────
# Default points at the standard local install. Override if your Ollama
# instance lives elsewhere.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:3b

# ─── Server ──────────────────────────────────────────────────────────
# Port the dev server listens on.
PORT=4321
# Host to bind to. Default `127.0.0.1` is loopback-only and is what you
# want for local development. Setting `0.0.0.0` exposes the server (and
# your Anthropic key, since there's no auth) to your LAN — do that only
# on a trusted network.
HOST=127.0.0.1

# ─── Sessions (server-side) ──────────────────────────────────────────
# Where the server writes per-session snapshots (one JSON file per
# session). Defaults to ./sessions; the directory is gitignored.
# DANDELION_SESSIONS_DIR=./sessions
